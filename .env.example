ENV="dev-fake"
# Set COMPOSE_PROJECT_NAME explicitly when running multiple QDash instances
# from different directories on the same server.
# COMPOSE_PROJECT_NAME=dev-fake-qdash
QDASH_INSTANCE=dev-fake-qdash
# SUBNET=""
# GATEWAY=""
DEFAULT_BACKEND="fake"

# QDASH_INSTANCE defaults to ${ENV}-qdash. Local and deploy tasks derive ports
# and the Compose project name from these values.

# Ports
# task deploy publishes the reverse proxy and Prefect only on 127.0.0.1 for
# SSH forwarding. Use different forward ports for each instance on the same
# server, e.g. 18080/14200 for dev and 18081/14201 for staging.
PROXY_PORT=18080
PREFECT_FORWARD_PORT=14200
MONGO_PORT=27017
MONGO_EXPRESS_PORT=8081
POSTGRES_PORT=5432
PREFECT_PORT=4200
API_PORT=5715
UI_PORT=5714
DEPLOYMENT_SERVICE_PORT=8001



# URLs
CLIENT_URL=http://localhost:${PROXY_PORT}
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_PREFECT_URL=http://localhost:${PREFECT_FORWARD_PORT}
# QDASH_LOCAL_HOST defaults to localhost.
# task deploy resolves templated CLIENT_URL and NEXT_PUBLIC_PREFECT_URL before
# passing values to Docker Compose. For Cloudflare deploys, CLIENT_URL defaults
# to https://${QDASH_HOST} when left templated or unset.
# QDASH_LOCAL_HOST=localhost
QDASH_UI_UPSTREAM=ui:5714
QDASH_API_UPSTREAM=api:5715
# Comma-separated hostnames allowed to access the Next.js dev server, e.g. 192.168.0.4
NEXT_ALLOWED_DEV_ORIGINS=
PREFECT_API_URL=http://localhost:${PREFECT_PORT}/api
INTERNAL_API_URL=http://api:${API_PORT}
# MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=example
MONGO_DB_NAME=qdash  # Change to "qdash" after migration

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=prefect
POSTGRES_DB=prefect

# Data paths
# Use unique data paths when running multiple QDash instances on the same
# server, e.g. ./postgres_data_dev and ./mongo_data_dev/data/db.
POSTGRES_DATA_PATH="./postgres_data"
MONGO_DATA_PATH="./mongo_data/data/db"
CALIB_DATA_PATH="./calib_data"
CALIB_TASKS_PATH="./src/qdash/workflow/calibtasks"
# Qubex backend configuration repository/data. QDash app config lives under ./config.
CONFIG_PATH="./config/qubex-config"

QDASH_ADMIN_USERNAME="admin"
QDASH_ADMIN_PASSWORD="passw0rd"

# Optional settings
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_APP_TOKEN=

# qubex-config repository (optional, for dynamic configuration management)
CONFIG_REPO_URL=
GITHUB_TOKEN=
GITHUB_USER=

# Cloudflare Tunnel remote access. Configure public hostnames to route to
# http://reverse-proxy:80. For production deploys, set QDASH_HOST to the public
# UI hostname; task deploy derives CLIENT_URL when it is left templated.
# QDASH_HOST=qdash.example.com
TUNNEL_TOKEN=
QDASH_API_TOKEN=

# CopilotKit AI Assistant (optional)
# Enable the AI chat assistant in the UI
NEXT_PUBLIC_COPILOT_ENABLED=true
OLLAMA_API_KEY=
OPENAI_API_KEY=
KNOWLEDGE_REPO_URL=
