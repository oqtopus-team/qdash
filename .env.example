ENV="dev-fake-qdash"
# SUBNET=""
# GATEWAY=""
DEFAULT_BACKEND="fake"

# Local instance defaults to ENV. task assign-local-ports derives ports,
# Compose project name, and reverse-proxy hostnames from it.

# Ports
PROXY_PORT=
MONGO_PORT=
MONGO_EXPRESS_PORT=
POSTGRES_PORT=
PREFECT_PORT=
API_PORT=
UI_PORT=
DEPLOYMENT_SERVICE_PORT=



# URLs
CLIENT_URL=http://${ENV}.localhost:${PROXY_PORT}
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_PREFECT_URL=http://prefect.${ENV}.localhost:${PROXY_PORT}
QDASH_UI_UPSTREAM=ui:5714
QDASH_API_UPSTREAM=api:5715
# Comma-separated hostnames allowed to access the Next.js dev server, e.g. 192.168.0.4
NEXT_ALLOWED_DEV_ORIGINS=
PREFECT_API_URL=http://localhost:${PREFECT_PORT}/api
INTERNAL_API_URL=http://api:${API_PORT}
# MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=example
MONGO_DB_NAME=qdash  # Change to "qdash" after migration

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=prefect
POSTGRES_DB=prefect

# Data paths
POSTGRES_DATA_PATH="./postgres_data"
MONGO_DATA_PATH="./mongo_data/data/db"
CALIB_DATA_PATH="./calib_data"
CALIB_TASKS_PATH="./src/qdash/workflow/calibtasks"
# Qubex backend configuration repository/data. QDash app config lives under ./config.
CONFIG_PATH="./config/qubex-config"

QDASH_ADMIN_USERNAME="admin"
QDASH_ADMIN_PASSWORD="passw0rd"

# Optional settings
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_APP_TOKEN=

# qubex-config repository (optional, for dynamic configuration management)
CONFIG_REPO_URL=
GITHUB_TOKEN=
GITHUB_USER=

# Cloudflare Tunnel remote access. Configure public hostnames to route to
# http://reverse-proxy:80. For production deploys, set QDASH_HOST and
# CLIENT_URL to the public UI hostname, for example:
# QDASH_HOST=qdash.example.com
# CLIENT_URL=https://qdash.example.com
TUNNEL_TOKEN=
QDASH_API_TOKEN=

# CopilotKit AI Assistant (optional)
# Enable the AI chat assistant in the UI
NEXT_PUBLIC_COPILOT_ENABLED=true
OLLAMA_API_KEY=
OPENAI_API_KEY=
KNOWLEDGE_REPO_URL=
